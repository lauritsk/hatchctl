amends "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Builtins.pkl"

local preCommitSteps = new Mapping<String, Step> {
  ["check-merge-conflict"] = Builtins.check_merge_conflict
  ["check-case-conflict"] = Builtins.check_case_conflict
  ["check-added-large-files"] = Builtins.check_added_large_files
  ["detect-private-key"] = Builtins.detect_private_key
  ["check-executables-have-shebangs"] = Builtins.check_executables_have_shebangs

  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["mixed-line-ending"] = Builtins.mixed_line_ending
  ["newlines"] = Builtins.newlines
  ["typos"] = Builtins.typos

  ["shellcheck"] = Builtins.shellcheck
  ["shfmt"] = Builtins.shfmt
  ["yamllint"] = Builtins.yamllint
  ["yamlfmt"] = Builtins.yamlfmt
  ["taplo"] = Builtins.taplo
  ["taplo-format"] = Builtins.taplo_format
  ["mise"] = Builtins.mise
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["markdown-lint"] = (Builtins.markdown_lint) {
    exclude = List("AGENTS.md", "CHANGELOG.md")
  }
  ["goreleaser-check"] = new Step {
    glob = ".goreleaser.yaml"
    check = "goreleaser check"
  }

  ["actionlint"] = Builtins.actionlint
  ["ghalint-action"] = Builtins.ghalint_action
  ["ghalint-workflow"] = Builtins.ghalint_workflow
  // ["zizmor"] = Builtins.zizmor

  ["go-fumpt"] = Builtins.go_fumpt
  ["go-vet"] = Builtins.go_vet
  ["staticcheck"] = Builtins.staticcheck
  ["err-check"] = Builtins.err_check

  ["go-vuln-check"] = Builtins.go_vuln_check
  ["go-sec"] = Builtins.go_sec
  ["trivy-fs"] = new Step {
    glob = "**/*"
    check =
      "trivy fs --scanners vuln,misconfig,secret --severity HIGH,CRITICAL --ignore-unfixed --skip-dirs internal/devcontainer/testdata --exit-code 1 ."
  }
  ["lychee"] = Builtins.lychee
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = preCommitSteps
  }
  ["commit-msg"] {
    steps {
      ["conventional-commit"] {
        check = "hk util check-conventional-commit {{commit_msg_file}}"
      }
    }
  }
  ["fix"] {
    fix = true
    steps = preCommitSteps
  }
  ["check"] {
    steps = preCommitSteps
  }
}
